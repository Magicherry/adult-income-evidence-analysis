\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Selected categorical feature distributions with positive-income rates. Household structure (\texttt  {marital\_status}, \texttt  {relationship}) and occupation-related variables already show large income-class differences before formal modelling.}}{6}{figure.caption.3}\protected@file@percent }
