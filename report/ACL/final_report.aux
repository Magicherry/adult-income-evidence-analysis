\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces PurrRobust seed stability. Held-out test ROC-AUC across three stratified random splits. PurrPoly consistently leads at every seed. All models show narrow variation, confirming that the main conclusions do not depend on a specific random split.}}{10}{table.caption.18}\protected@file@percent }
\newlabel{tab:robustness}{{7}{10}{PurrRobust seed stability. Held-out test ROC-AUC across three stratified random splits. PurrPoly consistently leads at every seed. All models show narrow variation, confirming that the main conclusions do not depend on a specific random split}{table.caption.18}{}}
